DB_HOST=localhost
DB_PORT=5432
DB_NAME=dengue_bi
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=saude
APP_ENV=dev
LOG_LEVEL=INFO
API_BASE_URL=https://apidadosabertos.saude.gov.br
API_TIMEOUT_SECONDS=30
API_MAX_RETRIES=3
API_BACKOFF_SECONDS=1.0
API_PAGE_SIZE=20
API_MAX_PAGES_PER_YEAR=500
API_USER=
API_PASSWORD=

PIPELINE_MODE=incremental
HISTORICAL_START_YEAR=2000
HISTORICAL_END_YEAR=2026
HISTORICAL_BATCH_YEARS=3
HISTORICAL_TRUNCATE_BEFORE_LOAD=true
INCREMENTAL_OVERLAP_DAYS=2
INCREMENTAL_FALLBACK_YEAR=2026

PORTAL_FORMATS=json,csv,xml
PORTAL_YEAR_START=2000
PORTAL_YEAR_END=2026
PORTAL_EXTRACT_ZIP=true
PORTAL_PERIODIC=false
PORTAL_INTERVAL_MINUTES=60

PORTAL_KEEP_ZIP=false
